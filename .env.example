# Environment variables required to run this project.

# Password for protected pages/routes
PAGE_ACCESS_PASSWORD=password

# Mailjet newsletter integration
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_NEWSLETTER_LIST_ID=123456
MAILJET_CONFIRM_TEMPLATE_ID=789012
MAILJET_SENDER_EMAIL=newsletter@yourdomain.com
MAILJET_SENDER_NAME=Your Name
# Optional override for template subject
MAILJET_CONFIRM_SUBJECT=Thanks for subscribing
